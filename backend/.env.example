# Copy to backend/.env for local dev. Never commit the real .env.
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# SQLite for local dev by default; set DATABASE_URL for Postgres.
DATABASE_URL=sqlite:///db.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Celery / Redis. Dev defaults to eager mode so no broker is needed; set
# ALWAYS_EAGER=False and point the URLs at a Redis instance to exercise the
# async pipeline locally.
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
